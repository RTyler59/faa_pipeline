# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST = "localhost"
DB_PORT = "5433"           # Using your verified port
DB_NAME = "faa_operators"  # Your shiny new database
DB_USER = "anythingllm_user"
DB_PASS = "kmg0331"

# ── Scraper ───────────────────────────────────────────────────────────────────
# Random float drawn from [THROTTLE_MIN, THROTTLE_MAX] seconds between requests
THROTTLE_MIN=2.0
THROTTLE_MAX=5.0

# Identifying user-agent — replace with your real contact URL or email
USER_AGENT=FAA-DataPipeline/1.0 (+https://github.com/yourorg/faa-pipeline; contact@example.com)

# Run Chromium in headless mode (true) or visible window (false — useful for debugging)
HEADLESS=true

# Playwright navigation/action timeout in milliseconds
PLAYWRIGHT_TIMEOUT=30000

# ── Retry ─────────────────────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3
RETRY_WAIT_MIN_SECONDS=4
RETRY_WAIT_MAX_SECONDS=60

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Runtime ───────────────────────────────────────────────────────────────────
# Comma-separated CFR parts to scrape; remove any you don't need
CFR_PARTS=121,125,129,133,135
